# PokerWars WebSocket Server - Environment Variables Template
# Copy this file to .env or set via your deployment platform.

NODE_ENV=development
PORT=8099
RECONNECT_GRACE_SECONDS=30
WS_MAX_PAYLOAD=65536
DATABASE_URL=postgresql://user:password@localhost:5432/pokerwars

# -----------------------------------------------------------------------------
# Allowed origins (web app hosts that can open WS connections)
# -----------------------------------------------------------------------------
ALLOWED_WS_ORIGINS=https://pokerwars.app
DEV_ALLOWED_WS_ORIGINS=http://localhost:8090,http://127.0.0.1:8090

# -----------------------------------------------------------------------------
# Optional Redis for persistence
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pokerwars?schema=public

# -----------------------------------------------------------------------------
# Game engine configuration
# -----------------------------------------------------------------------------
ACTION_TIMEOUT_SECONDS=15
GAME_START_COUNTDOWN_SECONDS=10
MIN_PLAYERS_TO_START=2
MAX_PLAYERS_PER_TABLE=9
STREET_DEAL_DELAY_SECONDS=3
NEW_HAND_DELAY_SECONDS=5
