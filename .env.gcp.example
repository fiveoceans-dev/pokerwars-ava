# GCP deployment configuration (Cloud Run)
# Copy to .env.gcp and fill in values.

PROJECT_ID=your-project-id
REGION=us-central1
REPO_NAME=poker-protocol

WEB_SERVICE_NAME=poker-web
WS_SERVICE_NAME=poker-ws

WEB_PUBLIC_URL=https://your-web-service-xxxxx-uc.a.run.app
WS_PUBLIC_URL=https://your-ws-service-xxxxx-uc.a.run.app

# Web runtime env (injected by start.sh)
NEXT_PUBLIC_APP_URL=$WEB_PUBLIC_URL
NEXT_PUBLIC_WS_URL=wss://your-ws-service-xxxxx-uc.a.run.app
NEXT_PUBLIC_API_URL=$WS_PUBLIC_URL/api

# WalletConnect/Web3Modal (optional)
WALLETCONNECT_PROJECT_ID=

# Hyperliquid chain configuration (required for web)
NEXT_PUBLIC_HYPERLIQUID_CHAIN_ID=
NEXT_PUBLIC_HYPERLIQUID_RPC_URL=
NEXT_PUBLIC_HYPERLIQUID_EXPLORER_URL=
NEXT_PUBLIC_HYPERLIQUID_CHAIN_NAME=Hyperliquid
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_SYMBOL=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_DECIMALS=18

NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_ID=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_RPC_URL=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_EXPLORER_URL=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_NAME=Hyperliquid Testnet
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_SYMBOL=tHYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_DECIMALS=18

# WebSocket server env
ALLOWED_WS_ORIGINS=$WEB_PUBLIC_URL
# Optional: Redis for persistence
REDIS_URL=
# Database (Cloud SQL Postgres for tournaments via Prisma)
DATABASE_URL=postgresql://user:password@host:5432/pokerwars?schema=public

# Optional: override Cloud Run ports (default 8080)
WEB_PORT=8080
WS_PORT=8080
