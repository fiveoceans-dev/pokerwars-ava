{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@hyper-poker/engine": ["../../packages/engine/src/index.ts"],
      "@hyper-poker/engine/*": ["../../packages/engine/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "game-engine/**",
    "game-engine-archived/**",
    "**/__tests__/**",
    "**/*.test.*"
  ]
}
