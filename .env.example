# ----------------------------------------------------------------
# Docker Compose & Database
# ----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pokerwars

# DATABASE_URL for the WS server (connecting to the local postgres container)
DATABASE_URL="postgresql://postgres:postgres@host.docker.internal:5432/pokerwars?schema=public"

# ----------------------------------------------------------------
# Web App Configuration
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=PokerWars
NEXT_PUBLIC_APP_DESCRIPTION="PokerWars is a tournament poker game."
NEXT_PUBLIC_APP_URL=http://localhost:8090
NEXT_PUBLIC_WS_URL=ws://localhost:8099
NEXT_PUBLIC_API_URL=http://localhost:8099/api

# WalletConnect (REQUIRED: Get a project ID from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=demo-placeholder-project-id
WALLETCONNECT_PROJECT_ID=demo-placeholder-project-id

# ----------------------------------------------------------------
# Hyperliquid Chain Configuration (Required for Web App)
# ----------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_NETWORK=hyperliquid-testnet

# Mainnet (Placeholders)
NEXT_PUBLIC_HYPERLIQUID_CHAIN_ID=999
NEXT_PUBLIC_HYPERLIQUID_CHAIN_NAME="Hyperliquid Mainnet"
NEXT_PUBLIC_HYPERLIQUID_RPC_URL=https://api.hyperliquid.xyz/evm
NEXT_PUBLIC_HYPERLIQUID_EXPLORER_URL=https://explorer.hyperliquid.xyz
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_SYMBOL=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_DECIMALS=18

# Testnet (Arbitrum Sepolia)
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_ID=421614
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_NAME="Hyperliquid Testnet"
NEXT_PUBLIC_HYPERLIQUID_TESTNET_RPC_URL=https://api.sepolia.hyperliquid.xyz/evm
NEXT_PUBLIC_HYPERLIQUID_TESTNET_EXPLORER_URL=https://explorer.sepolia.hyperliquid.xyz
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_SYMBOL=tHYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_DECIMALS=18
NEXT_PUBLIC_HYPERLIQUID_TESTNET_FAUCET_URL=https://faucet.hyperliquid.xyz

# ----------------------------------------------------------------
# WebSocket Server Configuration
# ----------------------------------------------------------------
ALLOWED_WS_ORIGINS=http://localhost:8090,http://localhost:8099
DEV_ALLOWED_WS_ORIGINS=http://localhost:8090,http://localhost:8099
WS_MAX_PAYLOAD=65536
RECONNECT_GRACE_SECONDS=30
