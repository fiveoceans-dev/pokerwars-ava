{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "~~/*": [
        "./*"
      ],
      "@hyper-poker/engine": [
        "./types/engine-shim.d.ts"
      ],
      "@hyper-poker/engine/*": [
        "./types/engine-shim.d.ts"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app/**/*",
    "config/**/*",
    "components/**/*",
    "game-engine.ts",
    "hooks/**/*",
    "next-env.d.ts",
    "next.config.mjs",
    "pages/**/*",
    "types/**/*.d.ts",
    "utils/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "server/game-engine/**",
    "server/game-engine-archived/**",
    "engine-tests/**",
    "**/__tests__/**",
    "**/*.test.*"
  ]
}
