// Prisma schema for PokerWars tournament orchestration
// Datasource points to Cloud SQL Postgres via DATABASE_URL

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TournamentType {
  STT
  MTT
}

enum TournamentStartMode {
  FULL
  SCHEDULED
}

enum TournamentStatus {
  REGISTERING
  SCHEDULED
  LATE_REG
  RUNNING
  BREAKING
  FINISHED
  CANCELLED
  TEMPLATE
}

enum BuyInCurrency {
  CHIPS
  TICKETS
}

enum PayoutMode {
  TOP_X_SPLIT
  TICKETS
}

enum RegistrationStatus {
  REGISTERED
  SEATED
  BUSTED
  CASHED
}

enum Asset {
  COINS
  TICKET_X
  TICKET_Y
  TICKET_Z
}

enum LedgerType {
  MINT
  BURN
  TRANSFER
  BUY_IN
  REFUND
  PAYOUT
  CONVERT_BUY
  CONVERT_SELL
  CLAIM_FREE
}

enum AccountOwnerType {
  USER
  TREASURY
  TOURNAMENT
  PROMO
}

enum GovernanceRole {
  ADMIN
  MANAGER
  PROMOTER
}

model UserRole {
  id        String         @id @default(cuid())
  userId    String
  role      GovernanceRole
  user      User           @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())

  @@unique([userId, role])
}

enum GameTemplateType {
  CASH
  SNG
  MTT
}

model User {
  id            String     @id @default(cuid())
  walletAddress String?    @unique
  email         String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  roles         UserRole[]
}

model Account {
  id           String            @id @default(cuid())
  ownerType    AccountOwnerType
  ownerId      String
  coins        BigInt            @default(0)
  ticket_x     BigInt            @default(0)
  ticket_y     BigInt            @default(0)
  ticket_z     BigInt            @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  balancePools BalancePool[]

  ledgerFrom LedgerTransaction[] @relation("LedgerFrom")
  ledgerTo   LedgerTransaction[] @relation("LedgerTo")
  escrow     TournamentEscrow?

  @@unique([ownerType, ownerId])
}

model LedgerTransaction {
  id            String     @id @default(cuid())
  seq           Int        @unique
  blockId       String?
  block         LedgerBlock? @relation(fields: [blockId], references: [id])
  prevHash      String?
  hash          String     @unique
  type          LedgerType
  fromAccountId String?
  toAccountId   String?
  fromAccount   Account?   @relation("LedgerFrom", fields: [fromAccountId], references: [id])
  toAccount     Account?   @relation("LedgerTo", fields: [toAccountId], references: [id])
  asset         Asset
  amount        BigInt
  referenceType String
  referenceId   String
  metadata      Json?
  createdAt     DateTime   @default(now())

  @@index([createdAt])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([blockId])
  @@index([referenceType, referenceId])
}

model Treasury {
  id                    String   @id
  coin_supply_total     BigInt
  coin_supply_remaining BigInt
  ticket_x_issued       Int      @default(0)
  ticket_y_issued       Int      @default(0)
  ticket_z_issued       Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model LedgerConfig {
  id                    String   @id @default("DEFAULT")
  coin_supply_total     BigInt   @default(5000000000)
  free_claim_amount     Int      @default(3000)
  free_claim_cooldown_ms Int     @default(18000000)
  buy_rate              Int      @default(250)
  sell_rate             Int      @default(220)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model LedgerBlock {
  id        String   @id @default(cuid())
  height    Int      @unique
  prevHash  String?
  hash      String
  txCount   Int
  createdAt DateTime @default(now())

  transactions LedgerTransaction[]
}

model TournamentEscrow {
  tournamentId String   @id
  accountId    String   @unique
  account      Account  @relation(fields: [accountId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tournament {
  id                String              @id
  name              String
  gameType          String              @default("No Limit Hold'em")
  type              TournamentType
  startMode         TournamentStartMode
  startAt           DateTime?
  lateRegMinutes    Int?
  status            TournamentStatus    @default(REGISTERING)
  maxPlayers        Int
  startingStack     Int
  blindScheduleId   String
  buyInCurrency     BuyInCurrency
  buyInAmount       Int
  payoutMode        PayoutMode
  payoutTopX        Int?
  payoutTicketCount Int?
  tableConfigId     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  levels        TournamentLevel[]
  registrations TournamentRegistration[]
  tables        TournamentTable[]
  events        TournamentEvent[]
  payouts       TournamentPayout[]
}

model TournamentLevel {
  id              String     @id @default(cuid())
  tournament      Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId    String
  levelIndex      Int
  smallBlind      Int
  bigBlind        Int
  ante            Int        @default(0)
  durationSeconds Int

  @@unique([tournamentId, levelIndex])
}

model TournamentRegistration {
  id           String             @id @default(cuid())
  tournament   Tournament         @relation(fields: [tournamentId], references: [id])
  tournamentId String
  playerId     String
  status       RegistrationStatus @default(REGISTERED)
  registeredAt DateTime           @default(now())
  tableId      String?
  seatIndex    Int?
  stack        Int?
  position     Int?

  @@unique([tournamentId, playerId])
}

model TournamentTable {
  id            String     @id @default(cuid())
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId  String
  engineTableId String     @unique // ID used by the EventEngine
  status        String     @default("ACTIVE")
  createdAt     DateTime   @default(now())
  closedAt      DateTime?
}

model TournamentEvent {
  id           String     @id @default(cuid())
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId String
  type         String
  payload      Json
  createdAt    DateTime   @default(now())
}

model TournamentPayout {
  id           String        @id @default(cuid())
  tournament   Tournament    @relation(fields: [tournamentId], references: [id])
  tournamentId String
  playerId     String
  amount       Int
  currency     BuyInCurrency
  createdAt    DateTime      @default(now())
}

model GameTemplate {
  id                String               @id
  name              String
  gameType          String               @default("No Limit Hold'em")
  type              GameTemplateType
  maxPlayers        Int
  smallBlind        Int
  bigBlind          Int
  minBuyIn          Int
  maxBuyIn          Int
  defaultBuyIn      Int
  currency          Asset                @default(COINS)
  startMode         TournamentStartMode?
  startAt           DateTime?
  schedule          String? // Cron-like schedule for recurring MTTs
  lateRegMinutes    Int?
  startingStack     Int?
  blindScheduleId   String?
  payoutMode        PayoutMode?
  payoutTopX        Int?
  payoutTicketCount Int?
  tableConfigId     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model SystemConfig {
  id               String   @id @default("default")
  templatesVersion Int      @default(1)
  updatedAt        DateTime @updatedAt
}

enum GovernanceRoleType {
  DIRECTOR
  MANAGER
  PROMOTER
  ADMIN
}

enum BalancePoolType {
  TREASURY
  PROMO
  CASH
  SNG
  MTT
}

model GameConfig {
  id                        String   @id @default("default")
  actionTimeoutSeconds      Int      @default(15)
  gameStartCountdownSeconds Int      @default(10)
  minPlayersToStart         Int      @default(2)
  maxPlayersPerTable        Int      @default(9)
  streetDealDelaySeconds    Int      @default(3)
  newHandDelaySeconds       Int      @default(5)
  updatedAt                 DateTime @updatedAt
}

model GovernanceAssignment {
  id        String             @id @default(cuid())
  wallet    String
  role      GovernanceRoleType
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([wallet, role])
}

model BalancePool {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  type        BalancePoolType
  asset       Asset
  accountId   String
  account     Account          @relation(fields: [accountId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([type])
}
