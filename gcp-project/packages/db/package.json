{
  "name": "@temp/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
