# Speed up Cloud Build by excluding local artifacts
.git
node_modules
**/node_modules
.next
**/.next
dist
**/dist
build
coverage
.DS_Store
*.log

# Ignore all environment files in the root and all subdirectories
# This ensures that variables MUST be passed via Docker mechanisms (args/environment)
.env
.env.*
**/.env
**/.env.*

# Explicitly allow example files if they are needed for documentation
!.env.example
!**/env.example

tmp
temp
**/tmp
**/temp