{
  "name": "pokernft-websocket-server",
  "version": "1.0.0",
  "description": "WebSocket server for PokerWars multiplayer game",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node -P tsconfig.dev.json -r tsconfig-paths/register src/index.ts",
    "dev:ws": "npm run dev",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "seed:games": "ts-node ./scripts/seed-game-templates.ts",
    "seed:initial": "ts-node ./scripts/seed-initial-data.ts",
    "seed:all": "npm run seed:initial && npm run seed:games",
    "test": "vitest",
    "deploy": "npm run build"
  },
  "dependencies": {
    "@hyper-poker/engine": "*",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.2.1",
    "ethers": "^6.12.0",
    "node-cron": "^4.2.1",
    "redis": "^4.7.0",
    "tsconfig-paths": "^4.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "babel-plugin-istanbul": {
      "test-exclude": "^7.0.1"
    }
  },
  "engines": {
    "node": ">=20",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "poker",
    "websocket",
    "multiplayer",
    "hyperliquid"
  ],
  "license": "MIT"
}
