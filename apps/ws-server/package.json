{
  "name": "pokernft-websocket-server",
  "version": "1.0.0",
  "description": "WebSocket server for PokerWars multiplayer game",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "dev:ws": "npm run dev",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "server-local": "./server-local.sh",
    "test": "vitest",
    "deploy": "git subtree push --prefix=packages/nextjs/server heroku main",
    "deploy-heroku": "./heroku-deploy.sh",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.2.1",
    "tsconfig-paths": "^4.2.0",
    "redis": "^4.7.0",
    "uuid": "^9.0.0",
    "ws": "^8.18.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "@hyper-poker/engine": "*"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "babel-plugin-istanbul": {
      "test-exclude": "^7.0.1"
    }
  },
  "engines": {
    "node": ">=20",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "poker",
    "websocket",
    "multiplayer",
    "hyperliquid"
  ],
  "license": "MIT"
}
