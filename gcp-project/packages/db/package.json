    "prisma:deploy": "prisma migrate deploy --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.8.3"
  }
}
