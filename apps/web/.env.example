# PokerWars Web Frontend environment variables
# Copy to .env.local for local development. For hosted environments, set via platform UI.

# App branding (used for metadata / sharing)
NEXT_PUBLIC_APP_NAME='PokerWars'
NEXT_PUBLIC_APP_DESCRIPTION='PokerWars is a tournament poker game.'
NEXT_PUBLIC_APP_URL=http://localhost:8090

# ---------------------------------------------------------------------------
# Core endpoints (order matters: production first to avoid localhost in hosted envs)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WS_URL=ws://localhost:8099
NEXT_PUBLIC_API_URL=http://localhost:8099/api

# Reown / WalletConnect project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Default network selection (hyperliquid-mainnet | hyperliquid-testnet)
NEXT_PUBLIC_DEFAULT_NETWORK=hyperliquid-mainnet

# ---------------------------------------------------------------------------
# Hyperliquid mainnet configuration
# ---------------------------------------------------------------------------
NEXT_PUBLIC_HYPERLIQUID_CHAIN_ID=
NEXT_PUBLIC_HYPERLIQUID_CHAIN_NAME='Hyperliquid Mainnet'
NEXT_PUBLIC_HYPERLIQUID_RPC_URL=
NEXT_PUBLIC_HYPERLIQUID_EXPLORER_URL=
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_SYMBOL=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_DECIMALS=18

# ---------------------------------------------------------------------------
# Hyperliquid testnet configuration
# ---------------------------------------------------------------------------
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_ID=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_NAME='Hyperliquid Testnet'
NEXT_PUBLIC_HYPERLIQUID_TESTNET_RPC_URL=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_EXPLORER_URL=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_SYMBOL=tHYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_DECIMALS=18

# Hyperliquid testnet faucet (optional)
NEXT_PUBLIC_HYPERLIQUID_TESTNET_FAUCET_URL=
