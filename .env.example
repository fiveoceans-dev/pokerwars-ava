# Base (non-secret) sample env for local development

PROJECT_ID="your-gcp-project"
REGION="us-central1"
REPO_NAME="pokerwars-repo"
WEB_SERVICE_NAME="poker-web"
WS_SERVICE_NAME="poker-ws"

WEB_PUBLIC_URL="http://localhost:8090"
WS_PUBLIC_URL="http://localhost:8099"

NEXT_PUBLIC_APP_URL=$WEB_PUBLIC_URL
NEXT_PUBLIC_WS_URL=$WS_PUBLIC_URL
NEXT_PUBLIC_API_URL="$WS_PUBLIC_URL/api"

WALLETCONNECT_PROJECT_ID="demo-placeholder-project-id"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=$WALLETCONNECT_PROJECT_ID

# Database placeholder (override with real secret in your private .env)
DATABASE_URL="postgresql://user:pass@localhost:5432/pokerwars"
