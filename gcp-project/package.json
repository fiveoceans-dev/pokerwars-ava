{
  "name": "temp-template",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build": "npm run build:web && npm run build:api",
    "prisma:generate": "npm --workspace packages/db run prisma:generate",
    "prisma:migrate": "npm --workspace packages/db run prisma:migrate",
    "prisma:deploy": "npm --workspace packages/db run prisma:deploy"
  }
}
