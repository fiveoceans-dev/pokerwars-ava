# Example env for PokerWars web (non-secret placeholders)
NEXT_PUBLIC_APP_NAME=PokerWars
NEXT_PUBLIC_APP_DESCRIPTION="PokerWars is a tournament poker game."
NEXT_PUBLIC_APP_URL=http://localhost:8090

NEXT_PUBLIC_WS_URL=ws://localhost:8099
NEXT_PUBLIC_API_URL=http://localhost:8099/api

# WalletConnect project ID (required for wallet modal)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=demo-placeholder-project-id
WALLETCONNECT_PROJECT_ID=demo-placeholder-project-id

# Default network selection
NEXT_PUBLIC_DEFAULT_NETWORK=avalanche-mainnet

# Avalanche mainnet (placeholders; defaults to public RPC if unset)
NEXT_PUBLIC_AVALANCHE_CHAIN_ID=43114
NEXT_PUBLIC_AVALANCHE_CHAIN_NAME="Avalanche C-Chain"
NEXT_PUBLIC_AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
NEXT_PUBLIC_AVALANCHE_EXPLORER_URL=https://snowtrace.io
NEXT_PUBLIC_AVALANCHE_CURRENCY_NAME=Avalanche
NEXT_PUBLIC_AVALANCHE_CURRENCY_SYMBOL=AVAX
NEXT_PUBLIC_AVALANCHE_CURRENCY_DECIMALS=18

# Avalanche testnet (Fuji)
NEXT_PUBLIC_AVALANCHE_TESTNET_CHAIN_ID=43113
NEXT_PUBLIC_AVALANCHE_TESTNET_CHAIN_NAME="Avalanche Fuji"
NEXT_PUBLIC_AVALANCHE_TESTNET_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_AVALANCHE_TESTNET_EXPLORER_URL=https://testnet.snowtrace.io
NEXT_PUBLIC_AVALANCHE_TESTNET_CURRENCY_NAME=Avalanche Fuji
NEXT_PUBLIC_AVALANCHE_TESTNET_CURRENCY_SYMBOL=AVAX
NEXT_PUBLIC_AVALANCHE_TESTNET_CURRENCY_DECIMALS=18
NEXT_PUBLIC_AVALANCHE_TESTNET_FAUCET_URL=https://faucet.avax.network

# Optional: Hyperliquid (legacy support)
NEXT_PUBLIC_HYPERLIQUID_CHAIN_ID=
NEXT_PUBLIC_HYPERLIQUID_CHAIN_NAME="Hyperliquid Mainnet"
NEXT_PUBLIC_HYPERLIQUID_RPC_URL=
NEXT_PUBLIC_HYPERLIQUID_EXPLORER_URL=
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_SYMBOL=HYPE
NEXT_PUBLIC_HYPERLIQUID_CURRENCY_DECIMALS=18

NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_ID=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CHAIN_NAME="Hyperliquid Testnet"
NEXT_PUBLIC_HYPERLIQUID_TESTNET_RPC_URL=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_EXPLORER_URL=
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_NAME=HYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_SYMBOL=tHYPE
NEXT_PUBLIC_HYPERLIQUID_TESTNET_CURRENCY_DECIMALS=18
NEXT_PUBLIC_HYPERLIQUID_TESTNET_FAUCET_URL=
