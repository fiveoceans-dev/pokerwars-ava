# GCP deployment defaults (no secrets)
PROJECT_ID="your-project-id"
REGION="us-central1"
REPO_NAME="pokerwars-repo"
WEB_SERVICE_NAME="poker-web"
WS_SERVICE_NAME="poker-ws"
WEB_PUBLIC_URL="https://pokerwars.xyz"
WS_PUBLIC_URL="https://ws.pokerwars.xyz"

# WalletConnect project ID (required)
WALLETCONNECT_PROJECT_ID="demo-placeholder-project-id"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="demo-placeholder-project-id"

# Database (replace with real connection string in your private env)
DATABASE_URL="postgresql://user:pass@host:5432/db"

# Optional tuning
ALLOWED_WS_ORIGINS="$WEB_PUBLIC_URL"
WS_MAX_PAYLOAD=65536
RECONNECT_GRACE_SECONDS=30
