# Core
NODE_ENV=development

# Web
WEB_PORT=3000

# API
API_PORT=8080
DATABASE_URL=postgresql://temp-user:temp-password@localhost:5432/temp-db

# GCP project
PROJECT_ID=your-project-id
REGION=us-central1

# Cloud Run services
WEB_SERVICE_NAME=temp-web
API_SERVICE_NAME=temp-api
REPO_NAME=temp-repo

# Cloud SQL
DB_INSTANCE=temp-instance
DB_NAME=temp-db
DB_USER=temp-user
DB_PASSWORD=replace-with-strong-password

# Cloud SQL socket URL for Cloud Run
DATABASE_URL_CLOUD=postgresql://$DB_USER:$DB_PASSWORD@/$DB_NAME?host=/cloudsql/$PROJECT_ID:$REGION:$DB_INSTANCE

# Optional VPC connector for private IP Cloud SQL
VPC_CONNECTOR=
