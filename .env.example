# Base (non-secret) sample env for local development
# Copy to .env for local scripts or to .env.gcp for Cloud Run deploy scripts.

PROJECT_ID="your-gcp-project"
REGION="us-central1"
REPO_NAME="pokerwars-repo"
WEB_SERVICE_NAME="poker-web"
WS_SERVICE_NAME="poker-ws"

WEB_PUBLIC_URL="http://localhost:8090"
WS_PUBLIC_URL="http://localhost:8099"

NEXT_PUBLIC_APP_URL="http://localhost:8090"
NEXT_PUBLIC_WS_URL="ws://localhost:8099"
NEXT_PUBLIC_API_URL="http://localhost:8099/api"

WALLETCONNECT_PROJECT_ID="demo-placeholder-project-id"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="demo-placeholder-project-id"

# WebSocket server origins
ALLOWED_WS_ORIGINS="http://localhost:8090"

# Database placeholder (override with real secret in your private .env)
DATABASE_URL="postgresql://user:pass@localhost:5432/pokerwars"
DATABASE_URL_CLOUD="postgresql://user:pass@/pokerwars?host=/cloudsql/your-project:us-central1:instance"
DB_INSTANCE="your-cloudsql-instance-name"

# Optional: auto-run migrations before WS deploy (scripts/gcp_deploy_ws.sh)
AUTO_MIGRATE="false"

# Optional: seed game templates when running scripts/db_bootstrap.sh
SEED_GAMES="false"
